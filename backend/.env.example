PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/hoodie_store
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Frontend URL used for CORS, payment redirects, and email links.
CLIENT_URL=http://localhost:3000

# Initial/admin owner account.
ADMIN_EMAIL=admin@yourstore.com
ADMIN_PASSWORD=ChangeMe123!

# Flutterwave.
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_WEBHOOK_SECRET=

# Cloudinary image storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email SMTP. Brevo works through SMTP with smtp-relay.brevo.com.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=HOODIE Store <no-reply@yourdomain.com>
